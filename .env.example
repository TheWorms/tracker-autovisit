# Port HTTP publié sur l'hôte -> dashboard sur http://localhost:<port>
Malinois_PORT=8080
# Fuseau horaire (utilisé par le cron de collecte et par Byparr)
TZ=Europe/Paris
# Planning cron par défaut (5 champs : min heure jour mois jourSemaine).
# Modifiable ensuite dans l'UI (Configuration). Ex. toutes les 12h : 0 */12 * * *
CRON_SCHEDULE=0 6 * * *
# Image du solveur Cloudflare (Byparr par défaut).
# ⚠️ Si Byparr crashe au démarrage avec "camoufox InvalidIP: Failed to get IP address"
#    (camoufox appelle public_ip() ; échoue selon l'egress réseau), bascule sur FlareSolverr
#    qui ne fait pas ce check IP. Interchangeable (même API /v1, même port 8191). Deux façons :
#  - rapide : remplace l'image ci-dessous par ghcr.io/flaresolverr/flaresolverr:latest
#  - propre : décommente le service "flaresolverr" du docker-compose.yml (et commente "byparr")
BYPARR_IMAGE=ghcr.io/thephaseless/byparr:latest
# FLARESOLVERR_IMAGE=ghcr.io/flaresolverr/flaresolverr:latest
