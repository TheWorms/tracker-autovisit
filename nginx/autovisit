server {
    listen 80;
    server_name ${CT_IP};
    root /var/www/autovisit;
    index index.html;

    location = /addsite.js { add_header Cache-Control "no-store"; }
    location = /index.html { add_header Cache-Control "no-store"; }

    # status.json passe par le service (protege par auth quand activee)
    location = /status.json {
        allow ${LAN_CIDR}; deny all;
        proxy_pass http://127.0.0.1:8099/status;
        proxy_set_header Host $host;
        proxy_set_header Cookie $http_cookie;
        add_header Cache-Control "no-store, no-cache, must-revalidate";
    }

    location ~ ^/auth/ {
        allow ${LAN_CIDR}; deny all;
        proxy_pass http://127.0.0.1:8099;
        proxy_set_header Host $host;
        proxy_set_header Cookie $http_cookie;
    }

    location ~ ^/(test|confirm|cancel|delete|toggle|sites|site|settings|favicon|logosync|inspect|logs|favsync|refreshall|refreshstate|revisit|revisitstate|sitestats|siterestore)$ {
        allow ${LAN_CIDR}; deny all;
        proxy_pass http://127.0.0.1:8099;
        proxy_set_header Host $host;
        proxy_set_header Cookie $http_cookie;
        client_max_body_size 4m;
        proxy_connect_timeout 20s;
        proxy_send_timeout 200s;
        proxy_read_timeout 200s;
    }
}
